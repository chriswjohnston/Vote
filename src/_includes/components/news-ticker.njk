{# ════════════════════════════════════════
   Component: news-ticker.njk

   Wraps the <news-ticker> web component.
   The JS web component is loaded from
   /assets/js/news-ticker.js

   Feed URL defaults to chriswjohnston.ca/news.json
   Override per-page with: tickerSrc attribute
   ════════════════════════════════════════ #}

<div class="ticker-wrap">
  <news-ticker
    src="{{ tickerSrc if tickerSrc else 'https://chriswjohnston.ca/news.json' }}"
    count="6"
    speed="45"
  ></news-ticker>
</div>

<script src="/assets/js/news-ticker.js" defer></script>
