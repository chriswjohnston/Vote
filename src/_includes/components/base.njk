{# ════════════════════════════════════════
   Layout: base.njk
   Used by all pages via front matter:
   layout: layouts/base.njk

   Required front matter per page:
   title: "Page Title"

   Optional:
   description: "Meta description"
   activePage: "About"   (highlights nav item)
   ════════════════════════════════════════ #}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>{{ title }} — Chris Johnston for Nipissing Township Council</title>
  <meta name="description" content="{{ description if description else 'Chris Johnston is a candidate for Nipissing Township Council in the October 2026 municipal election.' }}" />

  {# Fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Lato:wght@300;400;700&display=swap" rel="stylesheet" />

  {# Campaign styles #}
  <link rel="stylesheet" href="/assets/css/campaign.css" />
</head>
<body>

  {# Navigation #}
  {% include "components/nav.njk" %}

  {# News ticker — sits just below fixed nav #}
  {% include "components/news-ticker.njk" %}

  {# Page content pushed below nav + ticker #}
  <main class="page-offset">
    {{ content | safe }}
  </main>

  {# Footer #}
  {% include "components/footer.njk" %}

  {# Sender.net — load once, explicit mode so forms render on our terms #}
  <script>
    (function (s, e, n, d, er) {
      s['Sender'] = er;
      s[er] = s[er] || function () {
        (s[er].q = s[er].q || []).push(arguments)
      }, s[er].l = 1 * new Date();
      s[er].on = function (event, callback) {
        s[er].listeners = s[er].listeners || {};
        (s[er].listeners[event] = s[er].listeners[event] || []).push(callback);
      };
      var a = e.createElement(n),
          m = e.getElementsByTagName(n)[0];
      a.async = 1;
      a.src = d;
      m.parentNode.insertBefore(a, m)
    })(window, document, 'script',
      'https://cdn.sender.net/accounts_resources/universal.js?explicit=true',
      'sender');
    sender('1a931092951039')
  </script>

</body>
</html>
