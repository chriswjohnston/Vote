{# ════════════════════════════════════════
   Component: example.njk

   A self-contained governance example card.
   Stack multiple on a page — each is
   independent and can appear anywhere.

   Required front matter per include:
   ──────────────────────────────────
   Set variables before including:

   {% set exNumber    = "01" %}
   {% set exTitle     = "By-Law Discrepancy — Annual Appointments Ignored" %}
   {% set exCopy      = "Staff rolled committee memberships over year after year..." %}
   {% set exHowItShould = "Council is required under By-Law 2021-38 to..." %}
   {% set exCaseUrl   = "/priorities/governance/examples/boards-bylaws/" %}
   {% set exCaseLabel = "Full Case Study" %}

   exCaseUrl is optional — omit if no
   case study page exists for this example.
   ════════════════════════════════════════ #}

<div class="example-card">

  <div class="example-card-header">
    {% if exNumber %}
      <span class="example-num">{{ exNumber }}</span>
    {% endif %}
    <h3 class="example-title">{{ exTitle }}</h3>
  </div>

  <div class="example-card-body">

    <p class="example-copy">{{ exCopy }}</p>

    {% if exHowItShould %}
    <div class="example-how">
      <div class="example-how-label">How It Should Work</div>
      <p class="example-how-body">{{ exHowItShould }}</p>
    </div>
    {% endif %}

    {% if exCaseUrl %}
    <a class="example-link" href="{{ exCaseUrl }}">
      {{ exCaseLabel if exCaseLabel else "Full Case Study" }} →
    </a>
    {% endif %}

  </div>

</div>
