{# ════════════════════════════════════════
   Component: page-hero.njk

   Breadcrumb sits at the bottom of the
   hero, after the lead text.

   Required front matter:
   heroTitle: "When Projects Go Wrong"

   Optional:
   heroEyebrow: "Accountability · Project Track Record"
   heroTitleItalic: "and No One Asks Why"
   heroLead: "Nipissing Township has a documented pattern..."

   breadcrumbs:
     - label: "Priorities"
       url: "/priorities/"
     - label: "CAO Recruitment"
   ════════════════════════════════════════ #}

<div class="page-hero">
  <div class="page-hero-inner">

    {% if heroEyebrow %}
      <div class="page-hero-eyebrow">{{ heroEyebrow }}</div>
    {% endif %}

    <h1 class="page-hero-title">
      {{ heroTitle }}{% if heroTitleItalic %}<br><em>{{ heroTitleItalic }}</em>{% endif %}
    </h1>

    {% if heroLead %}
      <p class="page-hero-lead">{{ heroLead }}</p>
    {% endif %}

    {# Breadcrumb at bottom — only renders if defined in front matter #}
    {% include "components/breadcrumb.njk" %}

  </div>
</div>
