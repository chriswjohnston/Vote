{# ════════════════════════════════════════
   Component: case-study.njk

   Provides the chrome for each case study.
   Timeline and summary body are written
   as page content using Nunjucks blocks.

   Required front matter:
   ──────────────────────
   caseNumber:   "01"
   caseYear:     "2021"
   caseTitle:    "CAO Recruitment — $9,315 for a Process That Ended Behind Closed Doors"
   caseTldr:     "Plain language summary of what happened and why it matters."

   Optional front matter:
   ──────────────────────
   caseRefs:     "HR-CAO-RFP 2021 · Resolution R2021-142 · Resolution R2021-189"
   caseYoutubeId: "HUPTQajeFWk"
   caseYoutubeStart: 257        (seconds, optional)
   caseYoutubeCaption: "Video starts at 4:17 — the landfill card staff report."

   caseSummaryTitle:   "When Every Meeting Is Closed, You File an Ombudsman Complaint"
   caseSummaryEyebrow: "Accountability Action · 2022–2023"
   caseSummaryBody:    (multi-line prose — use page content block instead for long copy)
   caseSummaryCallout: "What this means: A resident without a council seat..."

   caseDifferently: "If elected, I won't need to write letters asking for answers..."

   evidence:
     - label: "Special Meeting Minutes — September 7, 2021"
       url: "https://nipissingtownship.com/..."
       type: external
     - label: "Ontario Ombudsman Report (January 30, 2023)"
       url: "/assets/docs/ombudsman-report-2023.pdf"
       type: pdf
     - label: "Resolution R2021-142"
       url: "https://bylaw.chriswjohnston.ca"
       type: external

   ════════════════════════════════════════ #}

<article class="case-study">
  <div class="case-study-inner">

    {# ── TL;DR ── #}
    {% if caseTldr %}
    <div class="case-study-tldr">
      <p>{{ caseTldr }}</p>
    </div>
    {% endif %}

    {# ── Eyebrow ── #}
    <div class="case-study-eyebrow">
      <span class="case-study-num">Project {{ caseNumber }}</span>
      {% if caseYear %}
        <span class="case-study-year">{{ caseYear }}</span>
      {% endif %}
    </div>

    {# ── Title ── #}
    <h1 class="case-study-title">{{ caseTitle }}</h1>

    {# ── Resolution refs ── #}
    {% if caseRefs %}
      <p class="case-study-refs">{{ caseRefs }}</p>
    {% endif %}

    {# ── Timeline — written in page body ── #}
    <div class="case-study-timeline">
      {{ content | safe }}
    </div>

    {# ── Summary ── #}
    {% if caseSummaryTitle %}
    <div class="case-study-summary">
      {% if caseSummaryEyebrow %}
        <div class="case-study-summary-eyebrow">{{ caseSummaryEyebrow }}</div>
      {% endif %}
      <h2 class="case-study-summary-title">{{ caseSummaryTitle }}</h2>
      {% if caseSummaryBody %}
        <div class="case-study-summary-body">{{ caseSummaryBody | safe }}</div>
      {% endif %}
      {% if caseSummaryCallout %}
        <div class="case-study-callout">
          <p><strong>What this means:</strong> {{ caseSummaryCallout }}</p>
        </div>
      {% endif %}
    </div>
    {% endif %}

    {# ── YouTube Embed (optional) ── #}
    {% if caseYoutubeId %}
    <div class="case-study-video">
      <div class="case-study-video-wrap">
        <iframe
          src="https://www.youtube.com/embed/{{ caseYoutubeId }}{% if caseYoutubeStart %}?start={{ caseYoutubeStart }}{% endif %}"
          title="Video for {{ caseTitle }}"
          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
          allowfullscreen
        ></iframe>
      </div>
      {% if caseYoutubeCaption %}
        <p class="case-study-video-caption">{{ caseYoutubeCaption }}</p>
      {% endif %}
    </div>
    {% endif %}

    {# ── How I'd Do It Differently ── #}
    {% if caseDifferently %}
    <div class="case-study-differently">
      <div class="case-study-differently-label">How I'd Do It Differently</div>
      <p>{{ caseDifferently }}</p>
    </div>
    {% endif %}

    {# ── Evidence ── #}
    {% if evidence %}
    <div class="case-study-evidence">
      <div class="case-study-evidence-label">Evidence</div>
      <ul class="case-study-evidence-list">
        {% for item in evidence %}
          <li class="case-study-evidence-item">
            <span class="case-study-evidence-icon">
              {% if item.type == "pdf" %}📄{% else %}🔗{% endif %}
            </span>
            <a href="{{ item.url }}" class="case-study-evidence-link"
              {% if item.type == "external" %}target="_blank" rel="noopener"{% endif %}
            >{{ item.label }}</a>
            {% if item.type == "pdf" %}
              <span class="case-study-evidence-badge">PDF</span>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

  </div>
</article>
