{# ════════════════════════════════════════
   Component: nav.njk
   Reads navigation tree from _data/nav.js
   Supports two levels of dropdowns.
   Pass `activePage` from page front matter
   to highlight the current section.
   ════════════════════════════════════════ #}

<nav class="nav">

  <a class="nav-logo" href="/">Chris <span>Johnston</span></a>

  {# ── Desktop Links ── #}
  <ul class="nav-links">
    {% for item in nav %}
      <li class="nav-item">

        {# Top-level link #}
        <a
          class="nav-link{% if item.children %} nav-link--has-children{% endif %}{% if activePage == item.label %} active{% endif %}"
          href="{{ item.url }}"
        >{{ item.label }}</a>

        {# First-level dropdown #}
        {% if item.children %}
          <ul class="nav-dropdown">
            {% for child in item.children %}

              {# Child has its own sub-children (e.g. Governance > Examples) #}
              {% if child.children %}
                <li class="nav-dropdown-group">
                  <span class="nav-dropdown-group-label">{{ child.label }}</span>
                  <ul class="nav-dropdown-sub">
                    {% for sub in child.children %}
                      <li>
                        <a class="nav-dropdown-link" href="{{ sub.url }}">{{ sub.label }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </li>
              {% else %}
                <li>
                  <a class="nav-dropdown-link" href="{{ child.url }}">{{ child.label }}</a>
                </li>
              {% endif %}

            {% endfor %}
          </ul>
        {% endif %}

      </li>
    {% endfor %}
  </ul>

  {# ── Hamburger ── #}
  <button class="nav-hamburger" id="nav-hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>

</nav>

{# ── Mobile Menu ── #}
<ul class="nav-mobile" id="nav-mobile" aria-hidden="true">
  {% for item in nav %}
    <li class="nav-mobile-item">
      <a class="nav-mobile-link" href="{{ item.url }}">{{ item.label }}</a>

      {# Mobile sub-links — flattened, no nesting #}
      {% if item.children %}
        <ul class="nav-mobile-sub">
          {% for child in item.children %}
            {% if child.children %}
              {% for sub in child.children %}
                <li>
                  <a class="nav-mobile-sub-link" href="{{ sub.url }}">{{ sub.label }}</a>
                </li>
              {% endfor %}
            {% else %}
              <li>
                <a class="nav-mobile-sub-link" href="{{ child.url }}">{{ child.label }}</a>
              </li>
            {% endif %}
          {% endfor %}
        </ul>
      {% endif %}

    </li>
  {% endfor %}
  <li>
    <a href="/#contact" class="nav-mobile-cta">Contact Me</a>
  </li>
</ul>

{# ── Hamburger Script ── #}
<script>
  (function () {
    var btn  = document.getElementById('nav-hamburger');
    var menu = document.getElementById('nav-mobile');

    btn.addEventListener('click', function () {
      var open = menu.classList.toggle('open');
      btn.classList.toggle('open', open);
      btn.setAttribute('aria-expanded', open);
      menu.setAttribute('aria-hidden', !open);
      document.body.style.overflow = open ? 'hidden' : '';
    });

    // Close on any mobile link click
    menu.querySelectorAll('a').forEach(function (link) {
      link.addEventListener('click', function () {
        menu.classList.remove('open');
        btn.classList.remove('open');
        btn.setAttribute('aria-expanded', 'false');
        menu.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      });
    });
  })();
</script>
