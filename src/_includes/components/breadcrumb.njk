{# ════════════════════════════════════════
   Component: breadcrumb.njk

   Usage — set in page front matter:
   breadcrumbs:
     - label: "Priorities"
       url: "/priorities/"
     - label: "Governance"
       url: "/priorities/governance/"
     - label: "CAO Recruitment"

   The last item is always the current page
   and renders without a link.
   ════════════════════════════════════════ #}

{% if breadcrumbs %}
<nav class="breadcrumb" aria-label="Breadcrumb">
  <div class="breadcrumb-inner">

    <a class="breadcrumb-link" href="/">Home</a>

    {% for crumb in breadcrumbs %}
      <span class="breadcrumb-sep" aria-hidden="true">›</span>

      {% if crumb.url %}
        <a class="breadcrumb-link" href="{{ crumb.url }}">{{ crumb.label }}</a>
      {% else %}
        <span class="breadcrumb-current" aria-current="page">{{ crumb.label }}</span>
      {% endif %}
    {% endfor %}

  </div>
</nav>
{% endif %}
