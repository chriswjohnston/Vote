{# ════════════════════════════════════════
   Component: breadcrumb.njk

   Renders inside .page-hero-inner, above
   the eyebrow line. No separate wrapper.

   Define in page front matter:
   breadcrumbs:
     - label: "Priorities"
       url: "/priorities/"
     - label: "Governance"
       url: "/priorities/governance/"
     - label: "CAO Recruitment"

   Last item has no url — renders as
   current page (no link).
   Home is always prepended automatically.
   ════════════════════════════════════════ #}

{% if breadcrumbs %}
<nav class="breadcrumb" aria-label="Breadcrumb">

  <a class="breadcrumb-link" href="/">Home</a>

  {% for crumb in breadcrumbs %}
    <span class="breadcrumb-sep" aria-hidden="true">›</span>

    {% if crumb.url %}
      <a class="breadcrumb-link" href="{{ crumb.url }}">{{ crumb.label }}</a>
    {% else %}
      <span class="breadcrumb-current" aria-current="page">{{ crumb.label }}</span>
    {% endif %}
  {% endfor %}

</nav>
{% endif %}
